
* {
    padding: 0;
    margin: 0;
    box-sizing: border-box;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}

body {
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background: linear-gradient(270deg, #FFD59A, burlywood, white);
    padding: 20px; 
}

#wrapper {
    display: flex;
    flex-direction: column; 
    align-items: center;    
    justify-content: center;
    width: 100%;
    height: 100%;
    max-width: 800px;      
    max-height: 800px;
    background-color: rgba(255, 255, 255, 0.85);
    padding: 30px;
    border-radius: 15px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    text-align: center;     
}

#titulo-text {
    margin-bottom: 10px;
    padding: 5px 15px;
    background-color: white;
    border-radius: 10px;
    border: 2px solid black;
}

#subtitulo-text {
    margin-bottom: 20px;
    font-size: 1.1rem;
}

#versododia {
    margin: 20px 0;
    font-style: italic;
    min-height: 50px; 
}

.verso {
    background: burlywood;
    padding: 10px 20px;
    border: 2px solid #333;
    border-radius: 5px;
    cursor: pointer;
    box-shadow: 0 5px 15px rgba(0,0,0,0.15);
    margin-top: 10px;
    width: 100%; 
    font-weight: bold;
    max-width: 200px;
    transition: transform 0.2s;
}

.verso:hover {
    transform: scale(1.03); 
}
